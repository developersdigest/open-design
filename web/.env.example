# Copy to .env.local and fill in.

# Moonshot (Kimi) API key — used by /api/mini-asset and /api/index-css for streaming HTML snippets.
# Get one at https://platform.moonshot.ai/
KIMI_API_KEY=sk-...

# Base path for the n8n brand webhooks. Used by /api/decode, /api/design, /api/html, /api/assets, /api/fonts.
# Defaults to http://localhost:5678/webhook/brand if unset — only set this if n8n runs elsewhere (e.g. tunnel, remote host).
N8N_BASE_URL=http://localhost:5678/webhook/brand

# Full URL for the legacy /api/generate route (single-shot all-in-one webhook). Required only if you use that route.
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/brand/decode
