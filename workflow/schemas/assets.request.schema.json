{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/assets.request.json",
  "title": "AssetsRequest",
  "description": "Request body for POST /webhook/brand/assets.",
  "type": "object",
  "properties": {
    "brand_run_id": { "type": "string" },
    "branding": { "type": "object", "additionalProperties": true },
    "copy": { "type": "object", "additionalProperties": true },
    "design_md": { "type": "string" },
    "strategy": { "type": "object", "additionalProperties": true }
  },
  "required": ["brand_run_id", "branding", "copy", "design_md", "strategy"],
  "additionalProperties": true,
  "examples": [
    {
      "brand_run_id": "test-run-1",
      "branding": {
        "colors": ["#635BFF", "#0A2540", "#FFFFFF"],
        "fonts": ["Sohne", "Camphor"],
        "logo": "https://stripe.com/img/v3/home/social.png"
      },
      "copy": {
        "brand_name": "Stripe",
        "tagline": "Financial infrastructure for the internet",
        "hero_headline": "Payments infrastructure for the internet",
        "tone": ["confident", "technical", "premium"]
      },
      "design_md": "# Stripe Visual Direction\n\n## At a glance\nPremium developer-first payments brand...",
      "strategy": {
        "brand_archetype": "The Sage",
        "mood_keywords": ["confident", "technical", "premium", "minimal", "trustworthy"]
      }
    }
  ]
}
