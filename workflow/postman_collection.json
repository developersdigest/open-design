{
  "info": {
    "name": "Open Design n8n API",
    "description": "Postman collection for the Open Design n8n webhook endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5678/webhook/brand",
      "type": "string"
    },
    {
      "key": "brand_run_id",
      "value": "test-run-1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Decode (Stripe)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Pre-request placeholder — no-op for now."
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "    pm.expect(pm.response.code).to.eql(200);",
              "});",
              "pm.test('copy.brand_name is a string', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.copy.brand_name).to.be.a('string');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{ \"url\": \"https://stripe.com\" }",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/decode",
          "host": ["{{baseUrl}}"],
          "path": ["decode"]
        }
      }
    },
