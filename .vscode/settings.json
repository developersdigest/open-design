{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "biomejs.biome",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[markdown]": {
    "editor.formatOnSave": false
  },
  "[makefile]": {
    "editor.insertSpaces": false
  },
  "typescript.tsdk": "web/node_modules/typescript/lib",
  "files.exclude": {
    "**/.next": true,
    "**/node_modules": true,
    "**/*.tsbuildinfo": true,
    "**/next-env.d.ts": true
  },
  "search.exclude": {
    "**/.next": true,
    "**/node_modules": true,
    "**/*.tsbuildinfo": true,
    "**/next-env.d.ts": true,
    "**/bun.lock": true
  }
}
